# Kaltura API test configuration
# Copy this file to .env and fill in your values

KALTURA_PARTNER_ID=your_partner_id
KALTURA_KS=your_kaltura_session_token
KALTURA_SERVICE_URL=https://www.kaltura.com/api_v3
KALTURA_AGENTS_MANAGER_URL=https://agents-manager.nvp1.ovp.kaltura.com
KALTURA_GENIE_URL=https://genie.nvp1.ovp.kaltura.com
KALTURA_APP_REGISTRY_URL=https://app-registry.nvp1.ovp.kaltura.com/api/v1
KALTURA_USER_PROFILE_URL=https://user.nvp1.ovp.kaltura.com/api/v1
KALTURA_MESSAGING_URL=https://messaging.nvp1.ovp.kaltura.com/api/v1
KALTURA_AUTH_BROKER_URL=https://auth.nvp1.ovp.kaltura.com/api/v1
KALTURA_EVENTS_API_URL=https://events-api.nvp1.ovp.kaltura.com/api/v1
KALTURA_REPORTS_URL=https://reports.nvp1.ovp.kaltura.com
KALTURA_SCM_URL=https://scm.nvp1.ovp.kaltura.com/api/v1

# Optional: needed for session.start tests and events platform tests
# KALTURA_ADMIN_SECRET=your_admin_secret
# KALTURA_USER_ID=user@example.com

# Optional: player uiConf ID for player embed tests (auto-detected if omitted)
# KALTURA_PLAYER_ID=57908212

# Optional: Genie category ID for AI search tests
# KALTURA_GENIE_CATEGORY_ID=406165862

# Optional: override the default clips catalog item ID
# KALTURA_CLIPS_CATALOG_ITEM_ID=34832

# Optional: Gmail account for email notification E2E delivery tests
# Requires a Google App Password (not your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
# TEST_GMAIL_ADDRESS=your-test@gmail.com
# TEST_GMAIL_APP_PASSWORD=your_app_password_here
