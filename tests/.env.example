# Kaltura API test configuration
# Copy this file to .env and fill in your values

KALTURA_PARTNER_ID=your_partner_id
KALTURA_KS=your_kaltura_session_token
KALTURA_SERVICE_URL=https://www.kaltura.com/api_v3
KALTURA_AGENTS_MANAGER_URL=https://agents-manager.nvp1.ovp.kaltura.com
KALTURA_GENIE_URL=https://genie.nvp1.ovp.kaltura.com

# Optional: override the default clips catalog item ID
# KALTURA_CLIPS_CATALOG_ITEM_ID=34832
